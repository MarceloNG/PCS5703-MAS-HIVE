<?xml version="1.0" encoding="UTF-8"?>
<organisational-specification id="hive_org"
    os-version="1.0"
    xmlns="http://moise.sourceforge.net/os">

  <!-- =================== STRUCTURAL SPECIFICATION =================== -->
  <!-- Estrutura FLAT (issue #38): um ÚNICO papel funcional que TODOS os agentes jogam.
       A hierarquia squad_leader→collector/assembler foi REMOVIDA — nenhum time do contest
       usou liderança centralizada (organizers, MAPC 2022: "it is usually not helpful to come
       up with a centralized solution"). A diferenciação funcional (explorar/coletar/montar) é
       por missão/crença dinâmica, não por papel fixo (jeito LI(A)RA: agentes homogêneos).
       max=20 admite o time do Sim1 — a soma das cardinalidades antigas era 19 < 20, e a org
       NEM ADMITIA os 20 agentes do Sim1. -->
  <structural-specification>

    <role-definitions>
      <role id="field_agent">
        <extends role="soc"/>
      </role>
    </role-definitions>

    <group-specification id="hive_team">
      <roles>
        <role id="field_agent" min="1" max="20"/>
      </roles>
      <!-- Sem links de autoridade: time flat/descentralizado. A alocação multi-bloco
           será Contract-Net DESCENTRALIZADO (issues #22/#21), não um líder central. -->
    </group-specification>

  </structural-specification>

  <!-- =================== FUNCTIONAL SPECIFICATION =================== -->
  <functional-specification>

    <scheme id="exploration_scheme">
      <goal id="map_explored">
        <plan operator="parallel">
          <goal id="dispensers_found" ttf="200"/>
          <goal id="goal_zones_found" ttf="200"/>
          <goal id="role_zones_found" ttf="200"/>
        </plan>
      </goal>
      <mission id="m_scout" min="1" max="15">
        <goal id="dispensers_found"/>
        <goal id="goal_zones_found"/>
        <goal id="role_zones_found"/>
      </mission>
    </scheme>

    <scheme id="task_execution_scheme">
      <goal id="task_submitted">
        <plan operator="sequence">
          <goal id="blocks_collected" ttf="100"/>
          <goal id="blocks_assembled" ttf="50"/>
          <goal id="pattern_submitted" ttf="30"/>
        </plan>
      </goal>
      <!-- FLAT (issue #38): m_collect max=15 — todos os 15 field_agents podem comprometer
           m_collect sem falha de cardinalidade. m_assemble/m_submit permanecem ESPECIFICADAS
           (o ciclo coletar→montar→submeter), mas sem norma — a alocação fina de montagem/submit
           volta como Contract-Net descentralizado (#22). -->
      <mission id="m_collect" min="1" max="15">
        <goal id="blocks_collected"/>
      </mission>
      <mission id="m_assemble" min="1" max="4">
        <goal id="blocks_assembled"/>
      </mission>
      <mission id="m_submit" min="1" max="4">
        <goal id="pattern_submitted"/>
      </mission>
    </scheme>

    <!-- Fase C / U4 + issue #38: a org DIRIGE a adoção do role MAPC `worker` — é o elo VIVO
         (a única coisa que a org genuinamente dirige e mede). Todos os field_agents comprometem
         m_adopt via n_adopt. O +step de role_adoption.asl adota; a org registra e descarrega
         (sem 2ª ação MASSim). ttf=400: cobre navegação 70x70 + exploração até a role-zone. -->
    <scheme id="adoption_scheme">
      <goal id="worker_role_adopted" ttf="400"/>
      <mission id="m_adopt" min="1" max="15">
        <goal id="worker_role_adopted"/>
      </mission>
    </scheme>

    <scheme id="defense_scheme">
      <goal id="team_protected">
        <plan operator="parallel">
          <goal id="goal_zones_guarded"/>
          <goal id="threats_cleared"/>
        </plan>
      </goal>
      <mission id="m_guard" min="1" max="3">
        <goal id="goal_zones_guarded"/>
        <goal id="threats_cleared"/>
      </mission>
    </scheme>

  </functional-specification>

  <!-- =================== NORMATIVE SPECIFICATION =================== -->
  <!-- FLAT (issue #38): o papel field_agent é obrigado a (a) ADOTAR worker — elo U4, o driver
       VIVO da org — e (b) COLETAR. As normas de montagem/submit/exploração/defesa saem: a
       alocação fina volta como Contract-Net descentralizado (#22), e exploração/coleta solo já
       são dirigidas pelo comportamento reativo (role_adoption.asl/navigation.asl), não pela org
       (KTD1). Garante R2 (todo role declarado compromete m_adopt) e R3 (toda norma referencia
       field_agent, que existe em role-definitions). -->
  <normative-specification>
    <norm id="n_adopt"   type="obligation" role="field_agent" mission="m_adopt"/>
    <norm id="n_collect" type="obligation" role="field_agent" mission="m_collect"/>
  </normative-specification>

</organisational-specification>
