{
  "server": {
    "tournamentMode": "round-robin",
    "teamsPerMatch": 1,
    "launch": "25s",
    "port": 12300,
    "backlog": 10000,
    "agentTimeout": 8000,
    "resultPath": "results",
    "logLevel": "normal",
    "logPath": "logs",
    "replayPath": "replays",
    "maxPacketLength": 65536,
    "waitBetweenSimulations": 5000
  },
  "match": [
    {
      "steps": 80,
      "randomSeed": 17,
      "randomFail": 0,
      "entities": { "standard": 15 },
      "clusterBounds": [1, 3],
      "roles": [
        { "name": "default", "vision": 5, "actions": ["skip", "move", "rotate", "adopt", "detach", "clear"], "speed": [1], "clear": { "chance": 0.7, "maxDistance": 1 } },
        { "name": "worker", "actions": ["request", "attach", "connect", "disconnect", "submit"], "speed": [2, 1, 1, 0] },
        { "name": "constructor", "actions": ["request", "attach", "connect", "disconnect", "submit"], "speed": [1] },
        { "name": "explorer", "vision": 7, "actions": ["survey", "attach"], "speed": [3, 0] },
        { "name": "digger", "speed": [1, 0], "clear": { "chance": 1, "maxDistance": 5 } }
      ],
      "clearEnergyCost": 2,
      "deactivatedDuration": 10,
      "maxEnergy": 100,
      "refreshEnergy": 50,
      "stepRecharge": 1,
      "clearDamage": [32, 16, 8, 4, 2, 1],
      "attachLimit": 10,
      "grid": {
        "height": 12,
        "width": 12,
        "instructions": [],
        "goals": { "number": 1, "size": [1, 1], "moveProbability": 0.0 },
        "roleZones": { "number": 0, "size": [1, 2] }
      },
      "blockTypes": [2, 2],
      "dispensers": [0, 0],
      "tasks": { "size": [1, 1], "concurrent": 1, "iterations": [5, 8], "maxDuration": [200, 400] },
      "events": { "chance": 0, "radius": [2, 3], "warning": 5, "create": [0, 0], "perimeter": 2 },
      "regulation": { "simultaneous": 1, "chance": 0, "subjects": [] },
      "absolutePosition": true,
      "setup": "../../conf/scenarios/setup/06c-collect-rotate.txt"
    }
  ],
  "teams": {
    "A": { "prefix": "agent", "password": "1" }
  },
  "assert": { "metric": "submits_ok", "min": 1 },
  "//": "Cenario 06c-collect-rotate (U3 / objetividade do submit #50/#52) — variante de 06c-single-collect que EXIGE rotacao. O bloco anexa em (1,0) mas a task pede (0,1) → 1 rotate(cw) alinha NO DISPENSER (pre-alinhamento U3), antes de navegar a goal-zone. Diferente de 06c-single-collect (rotacao-livre por construcao, que passaria mesmo com o codigo antigo), este cenario FALSEIA o pre-alinhamento: se U3 falhar, o bloco chega desalinhado e ou nao submete ou rotaciona NA ZONA (o analyzer submit_strategy.py detecta rotacoes-na-zona > 0). Grid 12x12, randomFail:0, seed 17, absolutePosition:true, 80 steps. METRICA: submits_ok >= 1.",
  "//setup": "Identico a 06c-single-collect (mesmas posicoes/seed), so muda a task t1 de (1,0) p/ (0,1) para exigir 1 rotacao. Validar com: submit_strategy.py --check (rotacoes-na-zona ≈ 0, rotacao no dispenser >= 1)."
}
