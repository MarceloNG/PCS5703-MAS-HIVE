{
  "server": {
    "tournamentMode": "round-robin",
    "teamsPerMatch": 1,
    "launch": "25s",
    "port": 12300,
    "backlog": 10000,
    "agentTimeout": 8000,
    "resultPath": "results",
    "logLevel": "normal",
    "logPath": "logs",
    "replayPath": "replays",
    "maxPacketLength": 65536,
    "waitBetweenSimulations": 5000
  },
  "match": [
    {
      "steps": 20,
      "randomSeed": 17,
      "randomFail": 0,
      "entities": { "standard": 1 },
      "clusterBounds": [1, 1],
      "roles": [
        { "name": "default", "vision": 5, "actions": ["skip", "move", "rotate", "adopt", "detach", "clear"], "speed": [1], "clear": { "chance": 0.7, "maxDistance": 1 } },
        { "name": "worker", "actions": ["request", "attach", "connect", "disconnect", "submit"], "speed": [2, 1, 1, 0] },
        { "name": "constructor", "actions": ["request", "attach", "connect", "disconnect", "submit"], "speed": [1] },
        { "name": "explorer", "vision": 7, "actions": ["survey", "attach"], "speed": [3, 0] },
        { "name": "digger", "speed": [1, 0], "clear": { "chance": 1, "maxDistance": 5 } }
      ],
      "clearEnergyCost": 2,
      "deactivatedDuration": 10,
      "maxEnergy": 100,
      "refreshEnergy": 50,
      "stepRecharge": 1,
      "clearDamage": [32, 16, 8, 4, 2, 1],
      "attachLimit": 10,
      "grid": {
        "height": 12,
        "width": 12,
        "instructions": [],
        "goals": { "number": 1, "size": [1, 1], "moveProbability": 0.0 },
        "roleZones": { "number": 1, "size": [1, 2] }
      },
      "blockTypes": [2, 2],
      "dispensers": [0, 0],
      "tasks": { "size": [1, 1], "concurrent": 1, "iterations": [5, 8], "maxDuration": [200, 400] },
      "events": { "chance": 0, "radius": [2, 3], "warning": 5, "create": [0, 0], "perimeter": 2 },
      "regulation": {
        "simultaneous": 1,
        "chance": 100,
        "subjects": [
          {
            "name": "Carry",
            "announcement": [2, 2],
            "duration": [70, 70],
            "punishment": [5, 5],
            "weight": 1,
            "optional": { "quantity": [1, 1] }
          }
        ]
      },
      "absolutePosition": true,
      "setup": "../../conf/scenarios/setup/09a-norm-carry.txt"
    }
  ],
  "teams": {
    "A": { "prefix": "agent", "password": "1" }
  },
  "assert": { "metric": "submits_ok", "min": 1 },
  "//": "Cenário 09a-norm-carry (Eixo 9a / issue #51 DoD). Isola o handler NORM com carry_limit=1: agentA4 pré-posicionado na goal+role-zone com 2 blocos pré-anexados (excesso a oeste + task block a leste). Verifica que NORM emite detach(w) correto [fix #51: filtro math.abs==1 + else{DDir=w} só alcançado por bloco adjacente real], task block sobrevive, e submit ocorre na sequência. quantity=[1,1] fixa carry_limit=1 (violação determinística com 2 blocos). chance:100 + announcement:[2,2] = norma ativa no step 3 (antes do handler disparar). ASSERT: submits_ok >= 1.",
  "//regulation": "chance:100 + announcement:[2,2] fixos → norma determinística (ativa step 3). ranges [X,X] tornam os sorteios de RNG irrelevantes (min=max). weight:1 (única subject → seleção trivial). quantity=[1,1]: carry_limit=1 fixo — 2 blocos pré-anexados = violação garantida."
}
