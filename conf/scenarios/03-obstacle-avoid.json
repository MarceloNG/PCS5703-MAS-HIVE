{
  "server": {
    "tournamentMode": "round-robin",
    "teamsPerMatch": 1,
    "launch": "25s",
    "port": 12300,
    "backlog": 10000,
    "agentTimeout": 8000,
    "resultPath": "results",
    "logLevel": "normal",
    "logPath": "logs",
    "replayPath": "replays",
    "maxPacketLength": 65536,
    "waitBetweenSimulations": 5000
  },
  "match": [
