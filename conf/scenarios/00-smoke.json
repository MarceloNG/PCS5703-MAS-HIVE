{
  "server": {
    "tournamentMode": "round-robin",
    "teamsPerMatch": 1,
    "launch": "25s",
    "port": 12300,
    "backlog": 10000,
    "agentTimeout": 8000,
    "resultPath": "results",
    "logLevel": "normal",
    "logPath": "logs",
    "replayPath": "replays",
    "maxPacketLength": 65536,
    "waitBetweenSimulations": 5000
  },
  "match": [
    {
      "steps": 30,
      "randomSeed": 17,
      "randomFail": 0,
      "entities": { "standard": 15 },
      "clusterBounds": [1, 3],
      "roles": [
        { "name": "default", "vision": 5, "actions": ["skip", "move", "rotate", "adopt", "detach", "clear"], "speed": [1], "clear": { "chance": 0.7, "maxDistance": 1 } },
        { "name": "worker", "actions": ["request", "attach", "connect", "disconnect", "submit"], "speed": [2, 1, 1, 0] },
        { "name": "constructor", "actions": ["request", "attach", "connect", "disconnect", "submit"], "speed": [1] },
        { "name": "explorer", "vision": 7, "actions": ["survey", "attach"], "speed": [3, 0] },
        { "name": "digger", "speed": [1, 0], "clear": { "chance": 1, "maxDistance": 5 } }
      ],
      "clearEnergyCost": 2,
      "deactivatedDuration": 10,
      "maxEnergy": 100,
      "refreshEnergy": 50,
      "stepRecharge": 1,
      "clearDamage": [32, 16, 8, 4, 2, 1],
      "attachLimit": 10,
      "grid": {
        "height": 15,
        "width": 15,
        "instructions": [],
        "goals": { "number": 1, "size": [1, 1], "moveProbability": 0.0 },
        "roleZones": { "number": 5, "size": [1, 2] }
      },
      "blockTypes": [1, 1],
      "dispensers": [1, 2],
      "tasks": { "size": [1, 1], "concurrent": 1, "iterations": [5, 8], "maxDuration": [200, 400] },
      "events": { "chance": 0, "radius": [2, 3], "warning": 5, "create": [0, 0], "perimeter": 2 },
      "regulation": { "simultaneous": 1, "chance": 0, "subjects": [] },
      "absolutePosition": true
    }
  ],
  "teams": {
    "A": { "prefix": "agent", "password": "1" }
  },
  "assert": { "metric": "role_adoption", "min": 1 },
  "//": "Cenario 00-smoke (harness #11): EXEMPLO de fiacao do harness, nao um experimento. Grid 15x15 deterministico (seed 17, randomFail 0, eventos/normas OFF, absolutePosition true), 40 steps, role-zones densas. METRICA de CAPACIDADE (nao score): role_adoption >= 1 (ao menos um agente adota worker => a cadeia default->explorer->worker fechou). O setup conf/scenarios/setup/00-smoke.txt e injetado no campo 'setup' pelo run-hive. Para um experimento real de adocao use o 01-adopt (issue #12); aqui o foco e so demonstrar/testar o harness."
}
