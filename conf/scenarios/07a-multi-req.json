        { "name": "worker", "actions": ["request", "attach", "connect", "disconnect", "submit"], "speed": [2, 1, 1, 0] },
        { "name": "constructor", "actions": ["request", "attach", "connect", "disconnect", "submit"], "speed": [1] },
        { "name": "explorer", "vision": 7, "actions": ["survey", "attach"], "speed": [3, 0] },
        { "name": "digger", "speed": [1, 0], "clear": { "chance": 1, "maxDistance": 5 } }
      ],
      "clearEnergyCost": 2,
      "deactivatedDuration": 10,
      "maxEnergy": 100,
      "refreshEnergy": 50,
      "stepRecharge": 1,
      "clearDamage": [32, 16, 8, 4, 2, 1],
      "attachLimit": 10,
      "grid": {
        "height": 12,
        "width": 12,
        "instructions": [],
        "goals": { "number": 1, "size": [1, 1], "moveProbability": 0.0 },
        "roleZones": { "number": 1, "size": [1, 2] }
      },
      "blockTypes": [2, 2],
      "dispensers": [0, 0],
      "tasks": { "size": [1, 1], "concurrent": 1, "iterations": [5, 8], "maxDuration": [200, 400] },
      "events": { "chance": 0, "radius": [2, 3], "warning": 5, "create": [0, 0], "perimeter": 2 },
      "regulation": { "simultaneous": 1, "chance": 0, "subjects": [] },
      "absolutePosition": true,
      "setup": "../../conf/scenarios/setup/07a-multi-req.txt"
    }
  ],
  "teams": {
    "A": { "prefix": "agent", "password": "1" }
  },
  "assert": { "metric": "submits_ok", "min": 1 },
  "//": "Cenário 07a-multi-req (Eixo 7a / issue #18) — submit de task MULTI-REQUISITO com blocos pré-alinhados. Generaliza o gate #14 (1 bloco) para N blocos: agentA4 (collector) tem 2 blocos pré-anexados em (1,0) e (2,0), task t1 exige exatamente esses 2 offsets → submit direto sem coletar. Isola a lógica multi-bloco da coleta (07b) e da rotação (07a'). Grid 12x12, randomFail:0, seed fixa, absolutePosition:true, 60 steps, dispensers:[0,0] (blocos vêm do setup).",
  "//setup": "Move 15 agentes a células distintas, agentA4 a (3,3) sobre role-zone, pré-anexa 2 blocos em cadeia leste: add (4,3) + attach(3,3,4,3) → bloco em (1,0); add (5,3) + attach(4,3,5,3) → bloco em (2,0). goal-zone em (3,7). task t1 = b1@(1,0) + b1@(2,0). PATH relativo ao cwd do servidor: '../../conf/...'."
}
